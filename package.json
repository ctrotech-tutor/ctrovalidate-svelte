{
  "name": "ctrovalidate-svelte",
  "version": "1.0.0",
  "description": "Svelte adapter for Ctrovalidate.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --tsconfig tsconfig.build.json",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint .",
    "format": "prettier . --check"
  },
  "peerDependencies": {
    "svelte": ">=3.0.0"
  },
  "dependencies": {
    "ctrovalidate-core": "^1.0.0"
  },
  "devDependencies": {
    "ctrovalidate-core": "^1.0.0",
    "tsup": "^8.5.1",
    "vitest": "^4.0.18",
    "eslint": "^9.39.2",
    "@eslint/js": "^9.39.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "prettier": "^3.1.1",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^17.2.0"
  },
  "author": "Ctrotech (https://github.com/ctrotech-tutor)",
  "license": "MIT"
}
